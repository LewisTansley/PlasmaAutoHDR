    return True


def settings_from_curve(
    curve_values: dict[str, object],
    base: dict[str, object],
    reference: int,
    max_nits: int,
) -> dict[str, object]:
    updated = base.copy()
    updated["ReferenceNits"] = clamp_reference_nits(float(curve_values["ReferenceNits"]))
    updated["MaxNits"] = clamp_curve_peak(
        float(curve_values["MaxNits"]), float(updated["ReferenceNits"]), max_nits
    )
    peak = float(updated["MaxNits"])
    sdr_x, sdr_y = parse_sdr_max_point(
        str(curve_values.get("SdrMaxPoint", "")),
        (peak, peak),
    )
    if "SdrMaxPoint" in curve_values and isinstance(curve_values["SdrMaxPoint"], tuple):
        sdr_x, sdr_y = curve_values["SdrMaxPoint"]
    ref = float(updated["ReferenceNits"])
    sdr_x, sdr_y = snap_sdr_max_point_for_save(sdr_x, sdr_y, peak)
    updated["SdrMaxPoint"] = format_sdr_max_point((sdr_x, sdr_y))
    updated["ToneCurvePoints"] = format_tone_curve_points(list(curve_values["ToneCurvePoints"]))
    updated["ToneCurvePreset"] = preset_to_string(str(curve_values.get("ToneCurvePreset", PRESET_CUSTOM)))
    updated["ToneCurveUserPresetId"] = str(curve_values.get("ToneCurveUserPresetId", "")).strip()
    updated["BlackPoint"] = clamp_black(float(curve_values.get("BlackPoint", updated.get("BlackPoint", 0.0))))
    updated["Vibrance"] = clamp_vibrance(float(curve_values.get("Vibrance", updated.get("Vibrance", 0.0))))
    updated["GamutExpansion"] = clamp_gamut_expansion(
        float(curve_values.get("GamutExpansion", updated.get("GamutExpansion", 1.5)))
    )
    return sanitize_settings(updated, reference, max_nits)


def commit_settings_dict(
    saved: dict[str, object],
    session: CalibrationSession,
) -> bool:
    if not session.app_key:
        print("AutoHDR: no app key for calibration", file=sys.stderr)
        return False

    write_app_profile(
        session.app_key,
        saved,
        display_name=session.display_name,
        window_class=session.window_class,
        resource_class=session.resource_class,
        desktop_file=session.desktop_file,
        auto_activate=True,
        register_app=session.is_new and not session.committed,
    )
    session.committed = True
    return dbus_call("reloadSettings")


@dataclass
class CalibrationSession:
    app_key: str
    display_name: str
    window_class: str
    resource_class: str
    desktop_file: str
    is_new: bool
    committed: bool = False


def restore_baseline(
    baseline_settings: dict[str, object],
    session: CalibrationSession,
) -> None:
    if not session.app_key:
        return

    if session.is_new:
        if session.committed:
            delete_app_profile(session.app_key)
    else:
        write_app_profile(
            session.app_key,
            baseline_settings,
            display_name=session.display_name,
            window_class=session.window_class,
            resource_class=session.resource_class,
            desktop_file=session.desktop_file,
            auto_activate=True,
            register_app=False,
        )


