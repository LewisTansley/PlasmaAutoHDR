def ensure_gui_environment() -> None:
    runtime = Path(os.environ.get("XDG_RUNTIME_DIR", f"/run/user/{os.getuid()}"))
    if "XDG_RUNTIME_DIR" not in os.environ and runtime.is_dir():
        os.environ["XDG_RUNTIME_DIR"] = str(runtime)
    if "DBUS_SESSION_BUS_ADDRESS" not in os.environ and runtime.is_dir():
        bus = runtime / "bus"
        if bus.exists():
            os.environ["DBUS_SESSION_BUS_ADDRESS"] = str(bus)
    if "WAYLAND_DISPLAY" not in os.environ and runtime.is_dir():
        for entry in sorted(runtime.glob("wayland-*")):
            if entry.is_socket():
                os.environ["WAYLAND_DISPLAY"] = entry.name
                break
    if "DISPLAY" not in os.environ:
        os.environ.setdefault("DISPLAY", ":1")


def qdbus_executable() -> str | None:
    return shutil.which("qdbus6") or shutil.which("qdbus")


def dbus_call(method: str, *args: object) -> bool:
    qdbus = qdbus_executable()
    if qdbus is None:
        print("AutoHDR: qdbus not found; cannot reach KWin effect", file=sys.stderr)
        return False

    command = [qdbus, DBUS_SERVICE, DBUS_PATH]
    if Path(qdbus).name == "qdbus6":
        command.append(method)
    else:
        command.extend([DBUS_INTERFACE, method])
    command.extend(str(arg) for arg in args)

    result = subprocess.run(
        command,
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode != 0:
        message = result.stderr.strip() or result.stdout.strip() or f"exit code {result.returncode}"
        print(f"AutoHDR D-Bus {method} failed: {message}", file=sys.stderr)
        return False
    return True


def read_hdr_limits() -> tuple[int, int]:
    reference = 100
    max_nits = 1000

    kwinrc = Path.home() / ".config/kwinrc"
    if kwinrc.is_file():
        parser = ConfigParser()
        parser.read(kwinrc)
        if parser.has_section("Windows_HDR"):
            reference = max(1, int(float(parser["Windows_HDR"].get("Reference", reference))))
            max_nits = max(reference + 1, int(float(parser["Windows_HDR"].get("MaxLuminance", max_nits))))

    output_config = Path.home() / ".config/kwinoutputconfig.json"
    if output_config.is_file():
        try:
            data = json.loads(output_config.read_text())
            for screen in data:
                for output in screen.get("data", []):
                    if not output.get("highDynamicRange", False):
                        continue
                    peak = int(output.get("maxPeakBrightnessOverride", 0) or 0)
                    if peak > max_nits:
                        max_nits = peak
        except (json.JSONDecodeError, TypeError, ValueError):
            pass

    return reference, max_nits


def migrate_midpoint(value: float) -> float:
    if value <= 1.0:
        if 0.25 <= value <= 0.75:
            return 80.0 + (value - 0.25) / 0.5 * 400.0
        return 203.0
    return max(80.0, min(480.0, value))


def migrate_sdr_max_point(entries: dict[str, str], peak: float) -> str:
    encoded = entries.get("SdrMaxPoint", "").strip()
    if encoded:
        return encoded
    if "MaxEndpointOutput" in entries:
        legacy_y = float(entries["MaxEndpointOutput"])
        return f"{round(peak)}:{round(legacy_y)}"
    return f"{round(peak)}:{round(peak)}"


def parse_sdr_max_point(encoded: str, fallback: tuple[float, float]) -> tuple[float, float]:
    if not encoded or ":" not in encoded:
        return fallback
    left, right = encoded.split(":", 1)
    try:
        return float(left), float(right)
    except ValueError:
        return fallback


def format_sdr_max_point(point: tuple[float, float]) -> str:
    return f"{round(point[0])}:{round(point[1])}"


def remap_tone_curve_input_to_sdr_space(
    sdr_max_point: tuple[float, float],
    intermediates: list[tuple[float, float]],
    reference: float,
    peak: float,
) -> tuple[tuple[float, float], list[tuple[float, float]]]:
    ref = max(reference, 1e-3)
    peak_val = max(peak, ref)

    def remap_x(x: float) -> float:
        if x <= ref + 1e-3:
            return x
        if x >= peak_val * 0.99:
            return ref
        return x * ref / peak_val

    sdr = (remap_x(sdr_max_point[0]), sdr_max_point[1])
    mids = [(remap_x(x), y) for x, y in intermediates]
    return sdr, mids


def sanitize_settings(settings: dict[str, object], reference: int, max_nits: int) -> dict[str, object]:
    result = settings.copy()
    ref = clamp_reference_nits(float(result.get("ReferenceNits", 203.0)))
    result["ReferenceNits"] = ref
    result["MaxNits"] = clamp_curve_peak(float(result["MaxNits"]), ref, max_nits)
    if float(result["GamutExpansion"]) < 0.0 or float(result["GamutExpansion"]) > 20.0:
        result["GamutExpansion"] = 1.5
    result["Vibrance"] = clamp_vibrance(float(result["Vibrance"]))
    result["GamutExpansion"] = clamp_gamut_expansion(float(result["GamutExpansion"]))
    result["BlackPoint"] = clamp_black(float(result["BlackPoint"]))
    peak = float(result["MaxNits"])
    preset = preset_from_string(str(result.get("ToneCurvePreset", "custom")))
    result["ToneCurvePreset"] = preset_to_string(preset)
    if preset != PRESET_CUSTOM:
        apply_tone_curve_preset(result, config_path())
    sdr_x, sdr_y = parse_sdr_max_point(str(result.get("SdrMaxPoint", "")), (peak, peak))
    if sdr_x <= 1e-6 and sdr_y <= 1e-6:
        sdr_x, sdr_y = ref, peak
    intermediates = parse_tone_curve_points(str(result.get("ToneCurvePoints", "")))
    (sdr_x, sdr_y), intermediates = remap_tone_curve_input_to_sdr_space((sdr_x, sdr_y), intermediates, ref, peak)
    intermediates = sanitize_intermediate_points(intermediates, sdr_x, peak, ref)
    sdr_x, sdr_y = sanitize_sdr_max_point(sdr_x, sdr_y, ref, peak, intermediates)
    result["SdrMaxPoint"] = format_sdr_max_point((sdr_x, sdr_y))
    result["ToneCurvePoints"] = format_tone_curve_points(intermediates)
    return result


def migrate_legacy_settings(settings: dict[str, object], entries: dict[str, str]) -> None:
    use_tone_curve = entries.get("UseToneCurve", "false").strip().lower() in {"true", "1", "yes", "on"}
    legacy_mid = migrate_midpoint(float(entries.get("MidPoint", settings.get("ReferenceNits", 203.0))))
    has_reference = "ReferenceNits" in entries
    has_sdr = "SdrMaxPoint" in entries or "MaxEndpointOutput" in entries

    if not use_tone_curve or not has_reference or not has_sdr:
        peak = float(settings["MaxNits"])
        ref = clamp_reference_nits(legacy_mid)
        settings["ReferenceNits"] = ref
        settings["SdrMaxPoint"] = format_sdr_max_point((ref, peak))
        settings["ToneCurvePoints"] = ""
        settings["ToneCurvePreset"] = PRESET_LINEAR


def apply_tone_curve_preset_after_read(settings: dict[str, object], entries: dict[str, str]) -> None:
    use_tone_curve = entries.get("UseToneCurve", "false").strip().lower() in {"true", "1", "yes", "on"}
    has_reference = "ReferenceNits" in entries
    has_sdr = "SdrMaxPoint" in entries or "MaxEndpointOutput" in entries
    if not use_tone_curve or not has_reference or not has_sdr:
        return

    if "ToneCurvePreset" in entries:
        preset = preset_from_string(entries["ToneCurvePreset"])
        settings["ToneCurvePreset"] = preset_to_string(preset)
        settings["ToneCurveUserPresetId"] = entries.get("ToneCurveUserPresetId", "").strip()
        if preset != PRESET_CUSTOM:
            apply_tone_curve_preset(settings, config_path())
    else:
        settings["ToneCurvePreset"] = PRESET_CUSTOM


def read_global_settings(reference: int, max_nits: int) -> dict[str, object]:
    settings = DEFAULT_SETTINGS.copy()
    settings["MaxNits"] = float(max_nits)

    entries = read_section_entries(parse_config_file(config_path()), GROUP_SETTINGS)
    for key, value in entries.items():
        canon = canonical_key(key)
        if canon is None:
            continue
        default = settings.get(canon)
        if default is None:
            continue
        settings[canon] = parse_config_value(canon, value, default)

    settings["SdrMaxPoint"] = migrate_sdr_max_point(entries, float(settings["MaxNits"]))
    migrate_legacy_settings(settings, entries)
    apply_tone_curve_preset_after_read(settings, entries)

    return sanitize_settings(settings, reference, max_nits)


def read_app_settings(app_key: str, reference: int, max_nits: int) -> dict[str, object] | None:
    parser = parse_config_file(config_path())
    section = app_group_name(app_key)
    if not parser.has_section(section):
        return None

    settings = read_global_settings(reference, max_nits)
    entries = read_section_entries(parser, section)
    for key, value in entries.items():
        canon = canonical_key(key)
        if canon is None:
            continue
        default = settings.get(canon)
        if default is None:
            continue
        settings[canon] = parse_config_value(canon, value, default)

    settings["SdrMaxPoint"] = migrate_sdr_max_point(entries, float(settings["MaxNits"]))
    migrate_legacy_settings(settings, entries)
    apply_tone_curve_preset_after_read(settings, entries)

    return sanitize_settings(settings, reference, max_nits)


def read_settings(reference: int, max_nits: int, app_key: str) -> dict[str, object]:
    if app_key:
        app_settings = read_app_settings(app_key, reference, max_nits)
        if app_settings is not None:
            return app_settings
    return read_global_settings(reference, max_nits)


def write_app_profile(
    app_key: str,
    settings: dict[str, object],
    *,
    display_name: str,
    window_class: str,
    resource_class: str,
    desktop_file: str,
    auto_activate: bool = True,
    register_app: bool = False,
) -> None:
    path = config_path()
    parser = parse_config_file(path)
    section = app_group_name(app_key)

    if not parser.has_section(section):
        parser.add_section(section)

    parser.set(section, "DisplayName", display_name or app_key)
    parser.set(section, "WindowClass", window_class)
    parser.set(section, "ResourceClass", resource_class)
    parser.set(section, "DesktopFile", desktop_file)
    parser.set(section, "AutoActivate", format_config_value("AutoActivate", auto_activate))

    for key in CONFIG_KEYS:
        if key not in settings:
            continue
        parser.set(section, key, format_config_value(key, settings[key]))

    if register_app:
        if not parser.has_section(GROUP_APPLICATIONS):
            parser.add_section(GROUP_APPLICATIONS)
        app_list_raw = parser.get(GROUP_APPLICATIONS, "AppList", fallback="")
        app_list = [item.strip() for item in re.split(r"[,\s]+", app_list_raw) if item.strip()]
        if app_key not in app_list:
            app_list.append(app_key)
        parser.set(GROUP_APPLICATIONS, "AppList", ",".join(app_list))

    write_config_file_atomic(path, parser)


def delete_app_profile(app_key: str) -> None:
    path = config_path()
    parser = parse_config_file(path)
    section = app_group_name(app_key)

    if parser.has_section(section):
        parser.remove_section(section)

    if parser.has_section(GROUP_APPLICATIONS) and parser.has_option(GROUP_APPLICATIONS, "AppList"):
        app_list_raw = parser.get(GROUP_APPLICATIONS, "AppList", fallback="")
        app_list = [item.strip() for item in re.split(r"[,\s]+", app_list_raw) if item.strip()]
        app_list = [item for item in app_list if item != app_key]
        if app_list:
            parser.set(GROUP_APPLICATIONS, "AppList", ",".join(app_list))
        else:
            parser.remove_option(GROUP_APPLICATIONS, "AppList")

    write_config_file_atomic(path, parser)


def clamp_curve_peak(value: float, reference_nits: float, max_nits: int) -> float:
    return max(clamp_reference_nits(reference_nits) + 1.0, min(float(max_nits), value))


def snap_sdr_max_point_for_save(sdr_x: float, sdr_y: float, peak_nits: float) -> tuple[float, float]:
    return sdr_x, min(sdr_y, peak_nits)


def clamp_black(value: float) -> float:
    return max(-0.01, min(0.01, value))


def clamp_vibrance(value: float) -> float:
    return max(0.0, min(10.0, value))


def clamp_gamut_expansion(value: float) -> float:
    return max(0.0, min(20.0, value))


def clamp_reference_nits(value: float) -> float:
    return max(REFERENCE_NITS_MIN, min(REFERENCE_NITS_MAX, value))


def parse_tone_curve_points(encoded: str) -> list[tuple[float, float]]:
    points: list[tuple[float, float]] = []
    for token in encoded.split(","):
        token = token.strip()
        if not token or ":" not in token:
            continue
        left, right = token.split(":", 1)
        try:
            points.append((float(left), float(right)))
        except ValueError:
            continue
    return points


def format_tone_curve_points(points: list[tuple[float, float]]) -> str:
    return ",".join(f"{round(x)}:{round(y)}" for x, y in points)


def _step_width_for_reference(reference_nits: float) -> float:
    return max(1.0, reference_nits * 0.005)


def _expand_step_knots_for_eval(
    points: list[tuple[float, float]],
    sdr_max_x: float,
    reference_nits: float,
    peak_nits: float,
) -> list[tuple[float, float]]:
    sorted_points = sorted(points, key=lambda item: item[0])
    min_x = 1e-3
    max_x = max(sdr_max_x - 1e-3, min_x)
    step_width = _step_width_for_reference(max(reference_nits, 1.0))
    same_x_tolerance = 1.0

    expanded: list[tuple[float, float]] = []
    group_x = 0.0
    group_y_min = 0.0
    group_y_max = 0.0
    in_group = False
    group_count = 0

    def flush_group() -> None:
        nonlocal in_group, group_count
        if not in_group:
            return
        if group_count > 1 and group_y_max > group_y_min + 1e-6:
            step_x = max(min_x, min(max_x, group_x))
            pre_x = max(min_x, min(step_x - step_width, step_x - 1e-6))
            expanded.append((pre_x, max(0.0, min(peak_nits, group_y_min))))
            expanded.append((step_x, max(0.0, min(peak_nits, group_y_max))))
        else:
            expanded.append((group_x, group_y_max))
        in_group = False
        group_count = 0

    for raw_x, raw_y in sorted_points:
        x = max(min_x, min(max_x, raw_x))
        y = max(0.0, min(peak_nits, raw_y))
        if not in_group:
            group_x = x
            group_y_min = y
            group_y_max = y
            in_group = True
            group_count = 1
            continue
        if abs(x - group_x) <= same_x_tolerance:
            group_y_min = min(group_y_min, y)
            group_y_max = max(group_y_max, y)
            group_x = max(group_x, x)
            group_count += 1
            continue
        flush_group()
        group_x = x
        group_y_min = y
        group_y_max = y
        in_group = True
        group_count = 1

    flush_group()
    return expanded


def sanitize_intermediate_points(
    points: list[tuple[float, float]],
    sdr_max_x: float,
    peak_nits: float,
    reference_nits: float,
) -> list[tuple[float, float]]:
    del reference_nits  # kept for call-site compatibility
    sorted_points = sorted(points, key=lambda item: item[0])
    min_x = 1e-3
    max_x = max(sdr_max_x - 1e-3, min_x)

    result: list[tuple[float, float]] = []
    last_x = 0.0
    last_y = 0.0

    for raw_x, raw_y in sorted_points:
        x = max(min_x, min(max_x, raw_x))
        y = max(0.0, min(peak_nits, raw_y))
        if x <= last_x + 1e-6:
            x = last_x + 1e-6
        if y < last_y:
            y = last_y
        if x >= max_x:
            continue
        result.append((x, y))
        last_x = x
        last_y = y

    return result


def sanitize_sdr_max_point(
    x: float, y: float, reference_nits: float, peak_nits: float, intermediate: list[tuple[float, float]]
) -> tuple[float, float]:
    min_x = 1e-3
    min_y = 0.0
    if intermediate:
        min_x = max(min_x, intermediate[-1][0] + 1e-3)
        min_y = max(min_y, intermediate[-1][1])
    max_input = max(reference_nits, 1e-3)
    x = max(min_x, min(max_input, x))
    y = max(min_y, min(peak_nits, y))
    return x, y


def build_full_curve(
    sdr_max_point: tuple[float, float],
    reference_nits: float,
    peak_nits: float,
    intermediate: list[tuple[float, float]],
) -> list[tuple[float, float]]:
    sdr_x, sdr_y = sdr_max_point
    expanded = _expand_step_knots_for_eval(intermediate, sdr_x, reference_nits, peak_nits)
    mids = sanitize_intermediate_points(expanded, sdr_x, peak_nits, reference_nits)
    sdr_x, sdr_y = sanitize_sdr_max_point(sdr_x, sdr_y, reference_nits, peak_nits, mids)
    curve: list[tuple[float, float]] = [(0.0, 0.0)]
    curve.extend(mids)
    curve.append((sdr_x, sdr_y))
    return curve


def _compute_monotone_slopes(points: list[tuple[float, float]]) -> list[float]:
    n = len(points)
    if n == 0:
        return []
    if n == 1:
        return [0.0]

    h = [max(points[i + 1][0] - points[i][0], 1e-6) for i in range(n - 1)]
    delta = [(points[i + 1][1] - points[i][1]) / h[i] for i in range(n - 1)]

    slopes = [0.0] * n
    slopes[0] = delta[0]
    slopes[-1] = delta[-1]

    for i in range(1, n - 1):
        if delta[i - 1] * delta[i] <= 0.0:
            slopes[i] = 0.0
        else:
            w1 = 2.0 * h[i] + h[i - 1]
            w2 = h[i] + 2.0 * h[i - 1]
            slopes[i] = (w1 + w2) / (w1 / delta[i - 1] + w2 / delta[i])

    for i in range(n - 1):
        if abs(delta[i]) < 1e-6:
            slopes[i] = 0.0
            slopes[i + 1] = 0.0
        else:
            alpha = slopes[i] / delta[i]
            beta = slopes[i + 1] / delta[i]
            tau = alpha * alpha + beta * beta
            if tau > 9.0:
                scale = 3.0 / (tau**0.5)
                slopes[i] = scale * alpha * delta[i]
                slopes[i + 1] = scale * beta * delta[i]

    return slopes


def _evaluate_hermite_segment(
    x: float, x0: float, x1: float, y0: float, y1: float, m0: float, m1: float
) -> float:
    h = max(x1 - x0, 1e-6)
    t = max(0.0, min(1.0, (x - x0) / h))
    t2 = t * t
    t3 = t2 * t
    h00 = 2.0 * t3 - 3.0 * t2 + 1.0
    h10 = t3 - 2.0 * t2 + t
    h01 = -2.0 * t3 + 3.0 * t2
    h11 = t3 - t2
    return h00 * y0 + h10 * h * m0 + h01 * y1 + h11 * h * m1


def evaluate_tone_curve(points: list[tuple[float, float]], input_nits: float) -> float:
    if not points:
        return input_nits
    if len(points) == 1:
        return points[0][1]
    if input_nits <= points[0][0]:
        return points[0][1]
    if input_nits >= points[-1][0]:
        return points[-1][1]

    if len(points) == 2:
        x0, y0 = points[0]
        x1, y1 = points[1]
        t = max(0.0, min(1.0, (input_nits - x0) / max(x1 - x0, 1e-6)))
        return y0 + t * (y1 - y0)

    segment = 0
    for i in range(len(points) - 1):
        if points[i][0] <= input_nits <= points[i + 1][0]:
            segment = i
            break

    slopes = _compute_monotone_slopes(points)
    x0, y0 = points[segment]
    x1, y1 = points[segment + 1]
    return _evaluate_hermite_segment(input_nits, x0, x1, y0, y1, slopes[segment], slopes[segment + 1])


def build_tone_curve_lut(
    points: list[tuple[float, float]], input_span: float, size: int = 256
) -> list[float]:
    span = max(input_span, 1e-3)
    lut: list[float] = []
    for i in range(size):
        u = i / (size - 1) if size > 1 else 0.0
        lut.append(evaluate_tone_curve(points, u * span))
    return lut


PRESET_CUSTOM = "custom"
PRESET_USER = "user"
PRESET_LINEAR = "linear"
PRESET_SCURVE = "scurve"
PRESET_SCURVE_BOOSTED = "scurve_boosted"
PRESET_SCURVE_LIFTED = "scurve_lifted"
PRESET_EXPONENTIAL = "exponential"

BUILT_IN_PRESETS = (
    PRESET_LINEAR,
    PRESET_SCURVE,
    PRESET_SCURVE_BOOSTED,
    PRESET_SCURVE_LIFTED,
    PRESET_EXPONENTIAL,
)

PRESET_SAMPLE_FRACTIONS = (0.25, 0.5, 0.75)
K_SCURVE_BOOST_STRENGTH = 0.65
K_SCURVE_LIFT_AMOUNT = 0.12
K_EXPONENTIAL_RATE = 2.4


def preset_to_string(preset: str) -> str:
    normalized = preset.strip().lower()
    if normalized in {*BUILT_IN_PRESETS, PRESET_CUSTOM, PRESET_USER}:
        return normalized
    return PRESET_CUSTOM


def preset_from_string(encoded: str) -> str:
    return preset_to_string(encoded)


def preset_display_name(preset: str) -> str:
    names = {
        PRESET_LINEAR: "Linear",
        PRESET_SCURVE: "S-Curve",
        PRESET_SCURVE_BOOSTED: "S-Curve Boosted",
        PRESET_SCURVE_LIFTED: "S-Curve Lifted",
        PRESET_EXPONENTIAL: "Exponential",
        PRESET_USER: "User Preset",
        PRESET_CUSTOM: "Custom",
    }
    return names.get(preset_to_string(preset), "Custom")


def _smoothstep(t: float) -> float:
    t = max(0.0, min(1.0, t))
    return t * t * (3.0 - 2.0 * t)


def _preset_mapping(preset: str, t: float) -> float:
    t = max(0.0, min(1.0, t))
    preset = preset_to_string(preset)
    if preset == PRESET_LINEAR:
        return t
    if preset == PRESET_SCURVE:
        return _smoothstep(t)
    if preset == PRESET_SCURVE_BOOSTED:
        s = _smoothstep(t)
        return t + K_SCURVE_BOOST_STRENGTH * (s - t)
    if preset == PRESET_SCURVE_LIFTED:
        return K_SCURVE_LIFT_AMOUNT + (1.0 - K_SCURVE_LIFT_AMOUNT) * _smoothstep(t)
    if preset == PRESET_EXPONENTIAL:
        import math

        k = K_EXPONENTIAL_RATE
        denom = math.exp(k) - 1.0
        if abs(denom) < 1e-6:
            return t
        return (math.exp(k * t) - 1.0) / denom
    return t


def generate_preset_intermediate_points(
    preset: str, reference_nits: float, peak_nits: float
) -> list[tuple[float, float]]:
    preset = preset_to_string(preset)
    if preset in {PRESET_CUSTOM, PRESET_LINEAR, PRESET_USER}:
        return []

    ref = max(reference_nits, 1e-3)
    peak = max(peak_nits, ref)
    points = [
        (t * ref, _preset_mapping(preset, t) * peak)
        for t in PRESET_SAMPLE_FRACTIONS
    ]
    return sanitize_intermediate_points(points, ref, peak, ref)


def apply_tone_curve_preset(settings: dict[str, object], cfg_path: Path | None = None) -> None:
    preset = preset_from_string(str(settings.get("ToneCurvePreset", PRESET_CUSTOM)))
    if preset == PRESET_CUSTOM:
        return
    if preset == PRESET_USER:
        preset_id = str(settings.get("ToneCurveUserPresetId", "")).strip()
        if not preset_id:
            return
        user_preset = load_user_tone_curve_preset(cfg_path or config_path(), preset_id)
        if user_preset is None:
            return
        apply_user_tone_curve_preset(settings, user_preset)
        return
    ref = float(settings["ReferenceNits"])
    peak = float(settings["MaxNits"])
    settings["SdrMaxPoint"] = format_sdr_max_point((ref, peak))
    settings["ToneCurvePoints"] = format_tone_curve_points(
        generate_preset_intermediate_points(preset, ref, peak)
    )


def sanitize_user_preset_key(raw: str) -> str:
    key = re.sub(r"[^a-z0-9._-]+", "_", raw.strip().lower())
    key = re.sub(r"_+", "_", key).strip("_")
    return key or "preset"


def user_preset_group_name(preset_id: str) -> str:
    return f"{PRESET_GROUP_PREFIX}{preset_id}"


def user_preset_combo_id(preset_id: str) -> str:
    return f"user:{preset_id}"


def is_user_preset_combo_id(combo_id: str) -> bool:
    return combo_id.startswith("user:")


def user_preset_id_from_combo_id(combo_id: str) -> str:
    return combo_id[5:] if is_user_preset_combo_id(combo_id) else ""


def format_normalized_points(points: list[tuple[float, float]]) -> str:
    return ",".join(f"{x:.4f}:{y:.4f}" for x, y in points)


def parse_normalized_points(encoded: str) -> list[tuple[float, float]]:
    points: list[tuple[float, float]] = []
    for token in encoded.split(","):
        token = token.strip()
        if not token or ":" not in token:
            continue
        left, right = token.split(":", 1)
        try:
            points.append((float(left), float(right)))
        except ValueError:
            continue
    return points


def format_sdr_max_fraction(point: tuple[float, float]) -> str:
    return f"{point[0]:.4f}:{point[1]:.4f}"


def parse_sdr_max_fraction(encoded: str, fallback: tuple[float, float] = (1.0, 1.0)) -> tuple[float, float]:
    if not encoded or ":" not in encoded:
        return fallback
    left, right = encoded.split(":", 1)
    try:
        return float(left), float(right)
    except ValueError:
        return fallback


@dataclass
class UserToneCurvePreset:
    id: str
    display_name: str
    normalized_points: list[tuple[float, float]]
    sdr_max_fraction: tuple[float, float] = (1.0, 1.0)


def normalize_current_curve(settings: dict[str, object]) -> UserToneCurvePreset:
    ref = max(float(settings["ReferenceNits"]), 1e-3)
    peak = max(float(settings["MaxNits"]), ref)
    sdr_x, sdr_y = parse_sdr_max_point(str(settings.get("SdrMaxPoint", "")), (peak, peak))
    if isinstance(settings.get("SdrMaxPoint"), tuple):
        sdr_x, sdr_y = settings["SdrMaxPoint"]
    intermediates = parse_tone_curve_points(str(settings.get("ToneCurvePoints", "")))
    if isinstance(settings.get("ToneCurvePoints"), list):
        intermediates = [(float(x), float(y)) for x, y in settings["ToneCurvePoints"]]
    preset_id = sanitize_user_preset_key(str(settings.get("ToneCurveUserPresetId", "preset")))
    return UserToneCurvePreset(
        id=preset_id,
        display_name=preset_id,
        normalized_points=[(x / ref, y / peak) for x, y in intermediates],
        sdr_max_fraction=(sdr_x / ref, sdr_y / peak),
    )


def apply_user_tone_curve_preset(settings: dict[str, object], preset: UserToneCurvePreset) -> None:
    ref = max(float(settings["ReferenceNits"]), 1e-3)
    peak = max(float(settings["MaxNits"]), ref)
    sdr_x = preset.sdr_max_fraction[0] * ref
    sdr_y = preset.sdr_max_fraction[1] * peak
    intermediates = [(x * ref, y * peak) for x, y in preset.normalized_points]
    intermediates = sanitize_intermediate_points(intermediates, sdr_x, peak, ref)
    sdr_x, sdr_y = sanitize_sdr_max_point(sdr_x, sdr_y, ref, peak, intermediates)
    settings["SdrMaxPoint"] = format_sdr_max_point((sdr_x, sdr_y))
    settings["ToneCurvePoints"] = format_tone_curve_points(intermediates)


def load_user_tone_curve_presets(cfg_path: Path) -> list[UserToneCurvePreset]:
    parser = parse_config_file(cfg_path)
    if not parser.has_section(GROUP_USER_PRESETS):
        return []
    ids_raw = parser.get(GROUP_USER_PRESETS, "PresetList", fallback="")
    ids = [item.strip() for item in re.split(r"[,\s]+", ids_raw) if item.strip()]
    presets: list[UserToneCurvePreset] = []
    for preset_id in ids:
        loaded = load_user_tone_curve_preset(cfg_path, preset_id)
        if loaded is not None:
            presets.append(loaded)
    return presets


def load_user_tone_curve_preset(cfg_path: Path, preset_id: str) -> UserToneCurvePreset | None:
    parser = parse_config_file(cfg_path)
    section = user_preset_group_name(preset_id)
    if not parser.has_section(section):
        return None
    entries = read_section_entries(parser, section)
    return UserToneCurvePreset(
        id=preset_id,
        display_name=entries.get("DisplayName", preset_id),
        normalized_points=parse_normalized_points(entries.get("NormalizedPoints", "")),
        sdr_max_fraction=parse_sdr_max_fraction(entries.get("SdrMaxFraction", "")),
    )


def save_user_tone_curve_preset(cfg_path: Path, preset: UserToneCurvePreset) -> bool:
    if not preset.id:
        return False
    parser = parse_config_file(cfg_path)
    if not parser.has_section(GROUP_USER_PRESETS):
        parser.add_section(GROUP_USER_PRESETS)
    ids_raw = parser.get(GROUP_USER_PRESETS, "PresetList", fallback="")
    ids = [item.strip() for item in re.split(r"[,\s]+", ids_raw) if item.strip()]
    if preset.id not in ids:
        ids.append(preset.id)
    parser.set(GROUP_USER_PRESETS, "PresetList", ",".join(ids))

    section = user_preset_group_name(preset.id)
    if not parser.has_section(section):
        parser.add_section(section)
    parser.set(section, "DisplayName", preset.display_name or preset.id)
    parser.set(section, "NormalizedPoints", format_normalized_points(preset.normalized_points))
    parser.set(section, "SdrMaxFraction", format_sdr_max_fraction(preset.sdr_max_fraction))
    write_config_file_atomic(cfg_path, parser)
    return True


def delete_user_tone_curve_preset(cfg_path: Path, preset_id: str) -> bool:
    if not preset_id:
        return False
    parser = parse_config_file(cfg_path)
    if parser.has_section(GROUP_USER_PRESETS):
        ids_raw = parser.get(GROUP_USER_PRESETS, "PresetList", fallback="")
        ids = [item.strip() for item in re.split(r"[,\s]+", ids_raw) if item.strip()]
        ids = [item for item in ids if item != preset_id]
        if ids:
            parser.set(GROUP_USER_PRESETS, "PresetList", ",".join(ids))
        elif parser.has_option(GROUP_USER_PRESETS, "PresetList"):
            parser.remove_option(GROUP_USER_PRESETS, "PresetList")
    section = user_preset_group_name(preset_id)
    if parser.has_section(section):
        parser.remove_section(section)
    write_config_file_atomic(cfg_path, parser)
    return True


def _points_match(
    a: list[tuple[float, float]], b: list[tuple[float, float]], tolerance_nits: float
) -> bool:
    if len(a) != len(b):
        return False
    for (ax, ay), (bx, by) in zip(a, b):
        if abs(ax - bx) > tolerance_nits or abs(ay - by) > tolerance_nits:
            return False
    return True


def _sdr_max_matches_preset(settings: dict[str, object], tolerance_nits: float) -> bool:
    ref = float(settings["ReferenceNits"])
    peak = float(settings["MaxNits"])
    sdr_x, sdr_y = parse_sdr_max_point(str(settings.get("SdrMaxPoint", "")), (peak, peak))
    return abs(sdr_x - ref) <= tolerance_nits and abs(sdr_y - peak) <= tolerance_nits


def detect_matching_preset(settings: dict[str, object], tolerance_nits: float = 2.0) -> str:
    if not _sdr_max_matches_preset(settings, tolerance_nits):
        return PRESET_CUSTOM

    intermediates = parse_tone_curve_points(str(settings.get("ToneCurvePoints", "")))
    if not intermediates:
        return PRESET_LINEAR

    ref = float(settings["ReferenceNits"])
    peak = float(settings["MaxNits"])
    for preset in BUILT_IN_PRESETS:
        if preset == PRESET_LINEAR:
            continue
        generated = generate_preset_intermediate_points(preset, ref, peak)
        if _points_match(intermediates, generated, tolerance_nits):
            return preset
    return PRESET_CUSTOM


def qt_available() -> bool:
    try:
