def canonical_key(key: str) -> str | None:
    lowered = key.strip().lower()
    for name in CONFIG_KEYS:
        if name.lower() == lowered:
            return name
    return None


def parse_config_file(config_path: Path) -> ConfigParser:
    parser = ConfigParser()
    parser.optionxform = str  # preserve key case
    if config_path.is_file():
        parser.read(config_path, encoding="utf-8")
    return parser


def write_config_file_atomic(config_path: Path, parser: ConfigParser) -> None:
    config_path.parent.mkdir(parents=True, exist_ok=True)
    tmp_path = config_path.with_name(config_path.name + ".tmp")
    with tmp_path.open("w", encoding="utf-8") as handle:
        parser.write(handle, space_around_delimiters=False)
    tmp_path.replace(config_path)


def read_section_entries(parser: ConfigParser, section: str) -> dict[str, str]:
    if not parser.has_section(section):
        return {}
    return {key: parser.get(section, key) for key in parser.options(section)}


def parse_config_value(key: str, value: str, default: object) -> object:
    if key == "AutoActivate":
        return value.strip().lower() in {"true", "1", "yes", "on"}
    if key == "ToneCurvePoints":
        return value.strip()
    if key == "ToneCurvePreset":
        return value.strip()
    if key == "ToneCurveUserPresetId":
        return value.strip()
    if key == "SdrMaxPoint":
        return value.strip()
    if isinstance(default, bool):
        return value.strip().lower() in {"true", "1", "yes", "on"}
    if isinstance(default, int):
        return int(float(value))
    return float(value)


def format_config_value(key: str, value: object) -> str:
    if key in {"ReferenceNits"}:
        return str(int(round(float(value))))
    if key == "SdrMaxPoint":
        return str(value)
    if key == "AutoActivate" or isinstance(value, bool):
        return "true" if value else "false"
    if key == "ToneCurvePoints":
        return str(value)
    if key == "ToneCurvePreset":
        return str(value)
    if key == "ToneCurveUserPresetId":
        return str(value)
    if isinstance(value, int):
        return str(int(value))
    return repr(float(value))


def app_group_name(app_key: str) -> str:
