"""AutoHDR calibration dialog — runs outside KWin with a full session GUI environment."""

from __future__ import annotations

import json
import os
import re
import shutil
import subprocess
import sys
from configparser import ConfigParser
from dataclasses import dataclass
from pathlib import Path

SLIDER_STEPS = 10_000

CONFIG_KEYS = (
    "MaxNits",
    "GamutExpansion",
    "BlackPoint",
    "Vibrance",
    "MidPoint",
    "HighlightExpansion",
    "HighlightLift",
    "HighlightRange",
)

METADATA_KEYS = (
    "DisplayName",
    "WindowClass",
    "ResourceClass",
    "DesktopFile",
    "AutoActivate",
)

DEFAULT_SETTINGS: dict[str, object] = {
    "MaxNits": 1000.0,
    "GamutExpansion": 1.5,
    "BlackPoint": 0.0,
    "Vibrance": 0.0,
    "MidPoint": 203.0,
    "HighlightExpansion": 1.0,
    "HighlightLift": 1.0,
    "HighlightRange": 0.0,
}

HIGHLIGHT_EXPANSION_MIN = 0.5
HIGHLIGHT_EXPANSION_MAX = 2.0
HIGHLIGHT_LIFT_MIN = 0.5
HIGHLIGHT_LIFT_MAX = 20.0
HIGHLIGHT_RANGE_MAX = 3.0

DBUS_SERVICE = "org.kde.kwin.effect.autohdr"
DBUS_INTERFACE = "org.kde.kwin.effect.autohdr"
DBUS_PATH = "/autohdr"

APP_GROUP_PREFIX = "App "
GROUP_GENERAL = "General"
GROUP_SETTINGS = "Settings"
GROUP_APPLICATIONS = "Applications"


def canonical_key(key: str) -> str | None:
    lowered = key.strip().lower()
    for name in CONFIG_KEYS:
        if name.lower() == lowered:
            return name
    return None


def parse_config_file(config_path: Path) -> ConfigParser:
    parser = ConfigParser()
    parser.optionxform = str  # preserve key case
    if config_path.is_file():
        parser.read(config_path, encoding="utf-8")
    return parser


def write_config_file_atomic(config_path: Path, parser: ConfigParser) -> None:
    config_path.parent.mkdir(parents=True, exist_ok=True)
    tmp_path = config_path.with_name(config_path.name + ".tmp")
    with tmp_path.open("w", encoding="utf-8") as handle:
        parser.write(handle, space_around_delimiters=False)
    tmp_path.replace(config_path)


def read_section_entries(parser: ConfigParser, section: str) -> dict[str, str]:
    if not parser.has_section(section):
        return {}
    return {key: parser.get(section, key) for key in parser.options(section)}


def parse_config_value(key: str, value: str, default: object) -> object:
    if key == "AutoActivate":
        return value.strip().lower() in {"true", "1", "yes", "on"}
    if isinstance(default, bool):
        return value.strip().lower() in {"true", "1", "yes", "on"}
    if isinstance(default, int):
        return int(float(value))
    return float(value)


def format_config_value(key: str, value: object) -> str:
    if key == "MidPoint":
        return str(int(round(float(value))))
    if key in {"AutoActivate"} or isinstance(value, bool):
        return "true" if value else "false"
    if isinstance(value, int):
        return str(int(value))
    return repr(float(value))


def app_group_name(app_key: str) -> str:
    return f"{APP_GROUP_PREFIX}{app_key}"


def config_path() -> Path:
    return Path.home() / ".config/kwin4effectautohdr"


def calibration_context() -> dict[str, str]:
    return {
        "app_key": os.environ.get("AUTOHDR_APP_KEY", "").strip(),
        "display_name": os.environ.get("AUTOHDR_APP_DISPLAY_NAME", "").strip(),
        "window_class": os.environ.get("AUTOHDR_WINDOW_CLASS", "").strip(),
        "resource_class": os.environ.get("AUTOHDR_RESOURCE_CLASS", "").strip(),
        "desktop_file": os.environ.get("AUTOHDR_DESKTOP_FILE", "").strip(),
        "is_new": os.environ.get("AUTOHDR_APP_IS_NEW", "").strip() == "1",
    }


def ensure_gui_environment() -> None:
    runtime = Path(os.environ.get("XDG_RUNTIME_DIR", f"/run/user/{os.getuid()}"))
    if "XDG_RUNTIME_DIR" not in os.environ and runtime.is_dir():
        os.environ["XDG_RUNTIME_DIR"] = str(runtime)
    if "DBUS_SESSION_BUS_ADDRESS" not in os.environ and runtime.is_dir():
        bus = runtime / "bus"
        if bus.exists():
            os.environ["DBUS_SESSION_BUS_ADDRESS"] = str(bus)
    if "WAYLAND_DISPLAY" not in os.environ and runtime.is_dir():
        for entry in sorted(runtime.glob("wayland-*")):
            if entry.is_socket():
                os.environ["WAYLAND_DISPLAY"] = entry.name
                break
    if "DISPLAY" not in os.environ:
        os.environ.setdefault("DISPLAY", ":1")


def qdbus_executable() -> str | None:
    return shutil.which("qdbus6") or shutil.which("qdbus")


def dbus_call(method: str, *args: object) -> bool:
    qdbus = qdbus_executable()
    if qdbus is None:
        print("AutoHDR: qdbus not found; cannot reach KWin effect", file=sys.stderr)
        return False

    command = [qdbus, DBUS_SERVICE, DBUS_PATH]
    if Path(qdbus).name == "qdbus6":
        command.append(method)
    else:
        command.extend([DBUS_INTERFACE, method])
    command.extend(str(arg) for arg in args)

    result = subprocess.run(
        command,
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode != 0:
        message = result.stderr.strip() or result.stdout.strip() or f"exit code {result.returncode}"
        print(f"AutoHDR D-Bus {method} failed: {message}", file=sys.stderr)
        return False
    return True


def read_hdr_limits() -> tuple[int, int]:
    reference = 100
    max_nits = 1000

    kwinrc = Path.home() / ".config/kwinrc"
    if kwinrc.is_file():
        parser = ConfigParser()
        parser.read(kwinrc)
        if parser.has_section("Windows_HDR"):
            reference = max(1, int(float(parser["Windows_HDR"].get("Reference", reference))))
            max_nits = max(reference + 1, int(float(parser["Windows_HDR"].get("MaxLuminance", max_nits))))

    output_config = Path.home() / ".config/kwinoutputconfig.json"
    if output_config.is_file():
        try:
            data = json.loads(output_config.read_text())
            for screen in data:
                for output in screen.get("data", []):
                    if not output.get("highDynamicRange", False):
                        continue
                    peak = int(output.get("maxPeakBrightnessOverride", 0) or 0)
                    if peak > max_nits:
                        max_nits = peak
        except (json.JSONDecodeError, TypeError, ValueError):
            pass

    return reference, max_nits


def migrate_midpoint(value: float) -> float:
    if value <= 1.0:
        if 0.25 <= value <= 0.75:
            return 80.0 + (value - 0.25) / 0.5 * 400.0
        return 203.0
    return max(80.0, min(480.0, value))


def sanitize_settings(settings: dict[str, object], reference: int, max_nits: int) -> dict[str, object]:
    result = settings.copy()
    if float(result["MaxNits"]) <= reference * 1.01:
        result["MaxNits"] = float(max_nits)
    else:
        result["MaxNits"] = min(float(result["MaxNits"]), float(max_nits))
    result["MidPoint"] = migrate_midpoint(float(result["MidPoint"]))
    if float(result["GamutExpansion"]) < 0.0 or float(result["GamutExpansion"]) > 20.0:
        result["GamutExpansion"] = 1.5
    result["Vibrance"] = clamp_vibrance(float(result["Vibrance"]))
    result["HighlightExpansion"] = clamp_highlight_expansion(float(result["HighlightExpansion"]))
    result["HighlightLift"] = clamp_highlight_lift(float(result["HighlightLift"]))
    result["HighlightRange"] = clamp_highlight_range(float(result.get("HighlightRange", 0.0)))
    result["GamutExpansion"] = clamp_gamut_expansion(float(result["GamutExpansion"]))
    result["BlackPoint"] = clamp_black(float(result["BlackPoint"]))
    return result


def read_global_settings(reference: int, max_nits: int) -> dict[str, object]:
    settings = DEFAULT_SETTINGS.copy()
    settings["MaxNits"] = float(max_nits)

    entries = read_section_entries(parse_config_file(config_path()), GROUP_SETTINGS)
    for key, value in entries.items():
        canon = canonical_key(key)
        if canon is None:
            continue
        default = settings.get(canon)
        if default is None:
            continue
        settings[canon] = parse_config_value(canon, value, default)

    return sanitize_settings(settings, reference, max_nits)


def read_app_settings(app_key: str, reference: int, max_nits: int) -> dict[str, object] | None:
    parser = parse_config_file(config_path())
    section = app_group_name(app_key)
    if not parser.has_section(section):
        return None

    settings = read_global_settings(reference, max_nits)
    entries = read_section_entries(parser, section)
    for key, value in entries.items():
        canon = canonical_key(key)
        if canon is None:
            continue
        default = settings.get(canon)
        if default is None:
            continue
        settings[canon] = parse_config_value(canon, value, default)

    return sanitize_settings(settings, reference, max_nits)


def read_settings(reference: int, max_nits: int, app_key: str) -> dict[str, object]:
    if app_key:
        app_settings = read_app_settings(app_key, reference, max_nits)
        if app_settings is not None:
            return app_settings
    return read_global_settings(reference, max_nits)


def write_app_profile(
    app_key: str,
    settings: dict[str, object],
    *,
    display_name: str,
    window_class: str,
    resource_class: str,
    desktop_file: str,
    auto_activate: bool = True,
    register_app: bool = False,
) -> None:
    path = config_path()
    parser = parse_config_file(path)
    section = app_group_name(app_key)

    if not parser.has_section(section):
        parser.add_section(section)

    parser.set(section, "DisplayName", display_name or app_key)
    parser.set(section, "WindowClass", window_class)
    parser.set(section, "ResourceClass", resource_class)
    parser.set(section, "DesktopFile", desktop_file)
    parser.set(section, "AutoActivate", format_config_value("AutoActivate", auto_activate))

    for key in CONFIG_KEYS:
        if key not in settings:
            continue
        parser.set(section, key, format_config_value(key, settings[key]))

    if register_app:
        if not parser.has_section(GROUP_APPLICATIONS):
            parser.add_section(GROUP_APPLICATIONS)
        app_list_raw = parser.get(GROUP_APPLICATIONS, "AppList", fallback="")
        app_list = [item.strip() for item in re.split(r"[,\s]+", app_list_raw) if item.strip()]
        if app_key not in app_list:
            app_list.append(app_key)
        parser.set(GROUP_APPLICATIONS, "AppList", ",".join(app_list))

    write_config_file_atomic(path, parser)


def delete_app_profile(app_key: str) -> None:
    path = config_path()
    parser = parse_config_file(path)
    section = app_group_name(app_key)

    if parser.has_section(section):
        parser.remove_section(section)

    if parser.has_section(GROUP_APPLICATIONS) and parser.has_option(GROUP_APPLICATIONS, "AppList"):
        app_list_raw = parser.get(GROUP_APPLICATIONS, "AppList", fallback="")
        app_list = [item.strip() for item in re.split(r"[,\s]+", app_list_raw) if item.strip()]
        app_list = [item for item in app_list if item != app_key]
        if app_list:
            parser.set(GROUP_APPLICATIONS, "AppList", ",".join(app_list))
        else:
            parser.remove_option(GROUP_APPLICATIONS, "AppList")

    write_config_file_atomic(path, parser)


def clamp_peak(value: float, reference: int, max_nits: int) -> float:
    return max(float(reference), min(float(max_nits), value))


def clamp_paper_white(value: float) -> float:
    return max(80.0, min(480.0, value))


def clamp_black(value: float) -> float:
    return max(-0.01, min(0.01, value))


def clamp_vibrance(value: float) -> float:
    return max(0.0, min(10.0, value))


def clamp_highlight_expansion(value: float) -> float:
    return max(HIGHLIGHT_EXPANSION_MIN, min(HIGHLIGHT_EXPANSION_MAX, value))


def clamp_highlight_lift(value: float) -> float:
    return max(HIGHLIGHT_LIFT_MIN, min(HIGHLIGHT_LIFT_MAX, value))


def clamp_highlight_range(value: float) -> float:
    return max(0.0, min(HIGHLIGHT_RANGE_MAX, value))


def clamp_gamut_expansion(value: float) -> float:
    return max(0.0, min(20.0, value))


@dataclass(frozen=True)
class SettingSpec:
    key: str
    label: str
    vmin: float
    vmax: float
    step: float
    integer: bool = False
    decimals: int = 1


def calibration_specs(reference: int, max_nits: int) -> list[SettingSpec]:
    return [
        SettingSpec("MaxNits", "Peak brightness (nits)", float(reference), float(max_nits), 10.0, True),
        SettingSpec("MidPoint", "Paper white (nits)", 80.0, 480.0, 1.0, True),
        SettingSpec("BlackPoint", "Black point", -0.01, 0.01, 0.0001, False, 4),
        SettingSpec("Vibrance", "Vibrance", 0.0, 10.0, 0.1),
        SettingSpec("HighlightExpansion", "Highlight expansion", HIGHLIGHT_EXPANSION_MIN, HIGHLIGHT_EXPANSION_MAX, 0.1),
        SettingSpec("HighlightLift", "Highlight lift", HIGHLIGHT_LIFT_MIN, HIGHLIGHT_LIFT_MAX, 0.1),
        SettingSpec("HighlightRange", "Highlight range", 0.0, HIGHLIGHT_RANGE_MAX, 0.1),
        SettingSpec("GamutExpansion", "Gamut expansion", 0.0, 20.0, 0.1),
    ]


def value_to_normalized(value: float, vmin: float, vmax: float) -> float:
    if vmax <= vmin:
        return 0.0
    return max(0.0, min(1.0, (value - vmin) / (vmax - vmin)))


def normalized_to_value(t: float, vmin: float, vmax: float, step: float) -> float:
    t = max(0.0, min(1.0, t))
    raw = vmin + t * (vmax - vmin)
    if step > 0.0:
        raw = vmin + round((raw - vmin) / step) * step
    return max(vmin, min(vmax, raw))


def qt_available() -> bool:
    try:
        import PySide6.QtWidgets  # noqa: F401, PLC0415
    except ImportError:
        return False
    return True


def clamp_setting_value(key: str, value: float, reference: int, max_nits: int) -> float:
    if key == "MaxNits":
        return clamp_peak(value, reference, max_nits)
    if key == "MidPoint":
        return clamp_paper_white(value)
    if key == "BlackPoint":
        return clamp_black(value)
    if key == "Vibrance":
        return clamp_vibrance(value)
    if key == "HighlightExpansion":
        return clamp_highlight_expansion(value)
    if key == "HighlightLift":
        return clamp_highlight_lift(value)
    if key == "HighlightRange":
        return clamp_highlight_range(value)
    if key == "GamutExpansion":
        return clamp_gamut_expansion(value)
    return value


def settings_from_values(
    values: dict[str, float], base: dict[str, object], reference: int, max_nits: int
) -> dict[str, object]:
    updated = base.copy()
    updated["MaxNits"] = clamp_peak(values["MaxNits"], reference, max_nits)
    updated["MidPoint"] = clamp_paper_white(values["MidPoint"])
    updated["BlackPoint"] = clamp_black(values["BlackPoint"])
    updated["Vibrance"] = clamp_vibrance(values["Vibrance"])
    updated["HighlightExpansion"] = clamp_highlight_expansion(values["HighlightExpansion"])
    updated["HighlightLift"] = clamp_highlight_lift(values["HighlightLift"])
    updated["HighlightRange"] = clamp_highlight_range(values["HighlightRange"])
    updated["GamutExpansion"] = clamp_gamut_expansion(values["GamutExpansion"])
    return updated


@dataclass
class CalibrationSession:
    app_key: str
    display_name: str
    window_class: str
    resource_class: str
    desktop_file: str
    is_new: bool
    committed: bool = False


def commit_settings(
    values: dict[str, float],
    base: dict[str, object],
    reference: int,
    max_nits: int,
    session: CalibrationSession,
) -> bool:
    saved = settings_from_values(values, base, reference, max_nits)
    if not session.app_key:
        print("AutoHDR: no app key for calibration", file=sys.stderr)
        return False

    write_app_profile(
        session.app_key,
        saved,
        display_name=session.display_name,
        window_class=session.window_class,
        resource_class=session.resource_class,
        desktop_file=session.desktop_file,
        auto_activate=True,
        register_app=session.is_new and not session.committed,
    )
    session.committed = True
    return dbus_call("reloadSettings")


def restore_baseline(
    baseline_settings: dict[str, object],
    session: CalibrationSession,
) -> None:
    if not session.app_key:
        return

    if session.is_new:
        if session.committed:
            delete_app_profile(session.app_key)
    else:
        write_app_profile(
            session.app_key,
            baseline_settings,
            display_name=session.display_name,
            window_class=session.window_class,
            resource_class=session.resource_class,
            desktop_file=session.desktop_file,
            auto_activate=True,
            register_app=False,
        )


def run_qt_form(
    settings: dict[str, object],
    baseline_settings: dict[str, object],
    reference: int,
    max_nits: int,
    session: CalibrationSession,
) -> bool:
    from PySide6.QtCore import Qt, Signal  # noqa: PLC0415
    from PySide6.QtWidgets import (  # noqa: PLC0415
        QAbstractSpinBox,
        QApplication,
        QDialog,
        QDialogButtonBox,
        QDoubleSpinBox,
        QHBoxLayout,
        QLabel,
        QSlider,
        QSpinBox,
        QVBoxLayout,
        QWidget,
    )

    class SettingRow(QWidget):
        committed = Signal()

        def __init__(self, spec: SettingSpec, value: float, parent: QWidget | None = None) -> None:
            super().__init__(parent)
            self.spec = spec
            self._block = False

            layout = QVBoxLayout(self)
            layout.setContentsMargins(0, 0, 0, 0)
            layout.addWidget(QLabel(spec.label))

            row = QHBoxLayout()
            self.slider = QSlider(Qt.Orientation.Horizontal)
            self.slider.setRange(0, SLIDER_STEPS)

            if spec.integer:
                spin: QSpinBox | QDoubleSpinBox = QSpinBox()
                spin.setRange(int(spec.vmin), int(spec.vmax))
                spin.setSingleStep(max(1, int(spec.step)))
            else:
                spin = QDoubleSpinBox()
                spin.setDecimals(spec.decimals)
                spin.setRange(spec.vmin, spec.vmax)
                spin.setSingleStep(spec.step)

            spin.setButtonSymbols(QAbstractSpinBox.ButtonSymbols.NoButtons)
            spin.setFixedWidth(72)
            self.spin = spin

            row.addWidget(self.slider, stretch=1)
            row.addWidget(spin)
            layout.addLayout(row)

            self.slider.valueChanged.connect(self._on_slider_changed)
            self.slider.sliderReleased.connect(self._on_slider_released)
            spin.valueChanged.connect(self._on_spin_changed)
            spin.editingFinished.connect(self._on_spin_committed)

            clamped = clamp_setting_value(spec.key, float(value), reference, max_nits)
            self._apply_value(clamped)

        def value(self) -> float:
            if self.spec.integer:
                return float(self.spin.value())
            return float(self.spin.value())

        def _slider_position(self, normalized: float) -> int:
            return int(round(max(0.0, min(1.0, normalized)) * SLIDER_STEPS))

        def _set_spin_value(self, value: float) -> None:
            if self.spec.integer:
                self.spin.setValue(int(round(value)))
            else:
                self.spin.setValue(value)

        def _apply_value(self, value: float) -> None:
            self._block = True
            normalized = value_to_normalized(value, self.spec.vmin, self.spec.vmax)
            self.slider.setValue(self._slider_position(normalized))
            self._set_spin_value(value)
            self._block = False

        def _on_slider_changed(self, _position: int) -> None:
            if self._block:
                return
            normalized = self.slider.value() / SLIDER_STEPS
            value = normalized_to_value(normalized, self.spec.vmin, self.spec.vmax, self.spec.step)
            self._apply_value(value)

        def _on_slider_released(self) -> None:
            self.committed.emit()

        def _on_spin_changed(self, spin_value: float | int) -> None:
            if self._block:
                return
            value = clamp_setting_value(self.spec.key, float(spin_value), reference, max_nits)
            self._apply_value(value)

        def _on_spin_committed(self) -> None:
            if self._block:
                return
            self.committed.emit()

    class CalibrationDialog(QDialog):
        def __init__(
            self,
            initial_settings: dict[str, object],
            dialog_baseline: dict[str, object],
            dialog_reference: int,
            dialog_max_nits: int,
            dialog_session: CalibrationSession,
            on_commit,
            parent: QWidget | None = None,
        ) -> None:
            super().__init__(parent)
            self.reference = dialog_reference
            self.max_nits = dialog_max_nits
            self.base_settings = initial_settings
            self.baseline_settings = dialog_baseline
            self.session = dialog_session
            self.on_commit = on_commit

            title = "AutoHDR Calibration"
            if dialog_session.display_name:
                title = f"{title} — {dialog_session.display_name}"
            self.setWindowTitle(title)
            self.setMinimumWidth(420)

            layout = QVBoxLayout(self)
            self.rows: dict[str, SettingRow] = {}
            for spec in calibration_specs(dialog_reference, dialog_max_nits):
                row = SettingRow(spec, float(initial_settings[spec.key]), self)
                row.committed.connect(self._commit_current)
                layout.addWidget(row)
                self.rows[spec.key] = row

            buttons = QDialogButtonBox(
                QDialogButtonBox.StandardButton.Ok | QDialogButtonBox.StandardButton.Cancel
            )
            confirm = buttons.button(QDialogButtonBox.StandardButton.Ok)
            if confirm is not None:
                confirm.setText("Confirm")
            buttons.accepted.connect(self._on_confirm)
            buttons.rejected.connect(self._on_cancel)
            layout.addWidget(buttons)

        def current_values(self) -> dict[str, float]:
            return {key: row.value() for key, row in self.rows.items()}

        def _commit_current(self) -> None:
            self.on_commit(self.current_values())

        def _on_confirm(self) -> None:
            if not self.on_commit(self.current_values()):
                return
            self.accept()

        def _on_cancel(self) -> None:
            restore_baseline(self.baseline_settings, self.session)
            dbus_call("reloadSettings")
            self.reject()

    app = QApplication.instance()
    owns_app = app is None
    if owns_app:
        app = QApplication(sys.argv)

    def persist_values(values: dict[str, float]) -> bool:
        if commit_settings(values, settings, reference, max_nits, session):
            return True
        show_error(
            "AutoHDR could not apply settings via D-Bus.\n"
            "Enable the AutoHDR effect in System Settings, reload KWin, then try again."
        )
        return False

    dialog = CalibrationDialog(settings, baseline_settings, reference, max_nits, session, persist_values)
    result = dialog.exec()

    if owns_app:
        app.quit()

    return result == QDialog.DialogCode.Accepted


def show_error(message: str) -> None:
    if qt_available():
        from PySide6.QtWidgets import QApplication, QMessageBox  # noqa: PLC0415

        app = QApplication.instance()
        owns_app = app is None
        if owns_app:
            app = QApplication(sys.argv)
        QMessageBox.critical(None, "AutoHDR Calibration", message)
        if owns_app:
            app.quit()
        return
    print(message, file=sys.stderr)


def run_dialog() -> int:
    ensure_gui_environment()

    if not qt_available():
        print("Install python-pyside6 to use the AutoHDR calibration dialog.", file=sys.stderr)
        return 1

    ctx = calibration_context()
    if not ctx["app_key"]:
        show_error("AutoHDR calibration requires an active application window.")
        return 1

    reference, max_nits = read_hdr_limits()
    settings = read_settings(reference, max_nits, ctx["app_key"])
    baseline_settings = settings.copy()

    session = CalibrationSession(
        app_key=ctx["app_key"],
        display_name=ctx["display_name"] or ctx["app_key"],
        window_class=ctx["window_class"],
        resource_class=ctx["resource_class"],
        desktop_file=ctx["desktop_file"],
        is_new=ctx["is_new"],
    )

    if not run_qt_form(settings, baseline_settings, reference, max_nits, session):
        return 1

    return 0


def main() -> int:
    try:
        return run_dialog()
    except Exception as error:  # noqa: BLE001 - show any startup failure in a dialog
        message = f"AutoHDR calibration failed:\n{error}"
        print(message, file=sys.stderr)
        if sys.argv[0].endswith("plasma-autohdr-calibrate") and len(sys.argv) == 1:
            show_error(message)
        return 1


if __name__ == "__main__":
    sys.exit(main())
