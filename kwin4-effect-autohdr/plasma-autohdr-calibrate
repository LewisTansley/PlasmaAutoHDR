                "MaxNits": self.peak_nits,
                "SdrMaxPoint": self.sdr_max_point,
                "ToneCurvePoints": list(self.intermediate_points),
                "ToneCurvePreset": self.tone_curve_preset,
                "ToneCurveUserPresetId": self.tone_curve_user_preset_id,
            }

        def _rebuild_preset_combo(self) -> None:
            previous_id = self._current_combo_id()
            self._block = True
            self.preset_combo.clear()
            for preset in BUILT_IN_PRESETS:
                self.preset_combo.addItem(preset_display_name(preset), preset)
            user_presets = load_user_tone_curve_presets(self._cfg_path)
            if user_presets:
                self.preset_combo.insertSeparator(self.preset_combo.count())
                for preset in user_presets:
                    self.preset_combo.addItem(preset.display_name, user_preset_combo_id(preset.id))
            self.preset_combo.insertSeparator(self.preset_combo.count())
            self.preset_combo.addItem(preset_display_name(PRESET_CUSTOM), PRESET_CUSTOM)
            index = self.preset_combo.findData(previous_id)
            if index >= 0:
                self.preset_combo.setCurrentIndex(index)
            self._block = False

        def _sync_preset_combo(self) -> None:
            index = self.preset_combo.findData(self._current_combo_id())
            if index >= 0:
                self._block = True
                self.preset_combo.setCurrentIndex(index)
                self._block = False

        def _update_preset_action_buttons(self) -> None:
            user_active = self.tone_curve_preset == PRESET_USER and bool(self.tone_curve_user_preset_id)
            self.save_preset_btn.setEnabled(True)
            self.update_preset_btn.setEnabled(user_active)
            self.delete_preset_btn.setEnabled(user_active)

        def _mark_custom_preset(self) -> None:
            if self.tone_curve_preset == PRESET_CUSTOM:
                return
            self.tone_curve_preset = PRESET_CUSTOM
            self.tone_curve_user_preset_id = ""
            self._sync_preset_combo()
            self._update_preset_action_buttons()

        def _apply_active_preset(self) -> None:
            if self.tone_curve_preset == PRESET_CUSTOM:
                return
            settings = self._current_settings()
            apply_tone_curve_preset(settings, self._cfg_path)
            self.sdr_max_point = parse_sdr_max_point(str(settings["SdrMaxPoint"]), (self.peak_nits, self.peak_nits))
            self.intermediate_points = parse_tone_curve_points(str(settings["ToneCurvePoints"]))

        def _set_preset_from_combo_id(self, combo_id: str, apply_curve: bool) -> None:
            if combo_id == PRESET_CUSTOM:
                return
            if is_user_preset_combo_id(combo_id):
                self.tone_curve_preset = PRESET_USER
                self.tone_curve_user_preset_id = user_preset_id_from_combo_id(combo_id)
            else:
                self.tone_curve_preset = preset_to_string(combo_id)
                self.tone_curve_user_preset_id = ""
            self._sync_preset_combo()
            self._update_preset_action_buttons()
            if apply_curve:
                self._apply_active_preset()
                self._sanitize_curve_points()

        def _on_preset_changed(self, index: int) -> None:
            if self._block or index < 0:
                return
            combo_id = str(self.preset_combo.itemData(index))
            self._set_preset_from_combo_id(combo_id, True)
            self.update()

        def _save_user_preset(self) -> None:
            self._read_spin_values()
            self._sanitize_curve_points()
            name, ok = QInputDialog.getText(self, "Save Tone Curve Preset", "Preset name:")
            name = str(name).strip()
            if not ok or not name:
                return
            preset = normalize_current_curve(self._current_settings())
            preset.id = sanitize_user_preset_key(name)
            preset.display_name = name
            if not save_user_tone_curve_preset(self._cfg_path, preset):
                return
            self.tone_curve_preset = PRESET_USER
            self.tone_curve_user_preset_id = preset.id
            self._rebuild_preset_combo()
            self._sync_preset_combo()
            self._update_preset_action_buttons()
            self.update()
            self.committed.emit()

        def _update_user_preset(self) -> None:
            if self.tone_curve_preset != PRESET_USER or not self.tone_curve_user_preset_id:
                return
            self._read_spin_values()
            self._sanitize_curve_points()
            preset = normalize_current_curve(self._current_settings())
            preset.id = self.tone_curve_user_preset_id
            existing = load_user_tone_curve_preset(self._cfg_path, self.tone_curve_user_preset_id)
            preset.display_name = existing.display_name if existing else self.tone_curve_user_preset_id
            save_user_tone_curve_preset(self._cfg_path, preset)
            self._rebuild_preset_combo()
            self._sync_preset_combo()
            self.update()
            self.committed.emit()

        def _delete_user_preset(self) -> None:
            if self.tone_curve_preset != PRESET_USER or not self.tone_curve_user_preset_id:
                return
            answer = QMessageBox.question(
                self,
                "Delete Tone Curve Preset",
                f'Delete preset "{self.tone_curve_user_preset_id}"?',
            )
            if answer != QMessageBox.StandardButton.Yes:
                return
            delete_user_tone_curve_preset(self._cfg_path, self.tone_curve_user_preset_id)
            self.tone_curve_preset = PRESET_CUSTOM
            self.tone_curve_user_preset_id = ""
            self._rebuild_preset_combo()
            self._sync_preset_combo()
            self._update_preset_action_buttons()
            self.update()
            self.committed.emit()

        def _peak_min(self) -> int:
            return int(round(self.reference_nits)) + 1

        def _sync_spin_ranges(self) -> None:
            self.peak_spin.setRange(self._peak_min(), self.max_nits_limit)
            self.reference_spin.setMaximum(
                min(int(REFERENCE_NITS_MAX), max(int(REFERENCE_NITS_MIN), int(round(self.peak_nits)) - 1))
            )

        def _maybe_snap_sdr_max_point(self, previous_peak: float) -> None:
            ref = self.reference_nits
            sdr_x, sdr_y = self.sdr_max_point
            if abs(sdr_x - ref) <= 1.0 and abs(sdr_y - previous_peak) <= 1.0:
                self.sdr_max_point = (ref, self.peak_nits)

        def _sanitize_curve_points(self) -> None:
            if self.sdr_max_point[0] <= 1e-6 and self.sdr_max_point[1] <= 1e-6:
                self.sdr_max_point = (self.reference_nits, self.peak_nits)
            self.intermediate_points = sanitize_intermediate_points(
                self.intermediate_points, self.sdr_max_point[0], self.peak_nits, self.reference_nits
            )
            self.sdr_max_point = sanitize_sdr_max_point(
                self.sdr_max_point[0], self.sdr_max_point[1], self.reference_nits, self.peak_nits, self.intermediate_points
            )

        def _enforce_peak_floor(self) -> None:
            peak_min = self._peak_min()
            if self.peak_nits < peak_min:
                previous_peak = self.peak_nits
                self.peak_nits = float(peak_min)
                self.peak_spin.setValue(peak_min)
                self._maybe_snap_sdr_max_point(previous_peak)
            self._sync_spin_ranges()

        def set_black_point(self, value: float) -> None:
            self._block = True
            self.black_point_value = clamp_black(value)
            self.black_point_spin.setValue(self.black_point_value)
            self._block = False

        def black_point(self) -> float:
            return self.black_point_value

        def _apply_spin_values(self) -> None:
            self._block = True
            self._sync_spin_ranges()
            self.peak_spin.setValue(int(round(self.peak_nits)))
            self.reference_spin.setValue(int(round(self.reference_nits)))
            self.black_point_spin.setValue(self.black_point_value)
            self.vibrance_spin.setValue(self.vibrance_value)
            self.gamut_spin.setValue(self.gamut_value)
            self._enforce_peak_floor()
            self._sanitize_curve_points()
            self._block = False
            self.update()

        def _read_spin_values(self) -> None:
            self.peak_spin.interpretText()
            self.reference_spin.interpretText()
            self.black_point_spin.interpretText()
            self.peak_nits = float(self.peak_spin.value())
            self.reference_nits = clamp_reference_nits(float(self.reference_spin.value()))
            self.black_point_value = clamp_black(float(self.black_point_spin.value()))
            self.vibrance_value = clamp_vibrance(float(self.vibrance_spin.value()))
            self.gamut_value = clamp_gamut_expansion(float(self.gamut_spin.value()))

        def _plot_host_rect(self) -> QRectF:
            top_left = self.plot_host.mapTo(self, QPoint(0, 0))
            return QRectF(float(top_left.x()), float(top_left.y()), self.plot_host.width(), self.plot_host.height())

        def _plot_rect(self) -> QRectF:
            return self._plot_host_rect().adjusted(0, PLOT_LABEL_TOP, 0, -PLOT_LABEL_BOTTOM)

        def _map_plot_event_pos(self, plot_local_pos: QPointF) -> QPointF:
            plot = self._plot_rect()
            return QPointF(plot.left() + plot_local_pos.x(), plot.top() + plot_local_pos.y() - PLOT_LABEL_TOP)

        def _interactive_rect(self) -> QRectF:
            return self._plot_rect().adjusted(-HIT_PADDING, -HIT_PADDING, HIT_PADDING, HIT_PADDING)

        def _nits_to_pixel(self, input_nits: float, output_nits: float) -> QPointF:
            plot = self._plot_rect()
            input_span = max(self.reference_nits, 1.0)
            output_span = max(self.peak_nits, 1.0)
            x = input_nits / input_span
            y = output_nits / output_span
            return QPointF(plot.left() + x * plot.width(), plot.bottom() - y * plot.height())

        def _pixel_to_nits(self, pixel: QPointF) -> tuple[float, float]:
            plot = self._plot_rect()
            input_span = max(self.reference_nits, 1.0)
            output_span = max(self.peak_nits, 1.0)
            x = max(0.0, min(1.0, (pixel.x() - plot.left()) / plot.width()))
            y = max(0.0, min(1.0, (plot.bottom() - pixel.y()) / plot.height()))
            return x * input_span, y * output_span

        def _full_curve(self) -> list[tuple[float, float]]:
            return build_full_curve(
                self.sdr_max_point, self.reference_nits, self.peak_nits, self.intermediate_points
            )

        def _hit_test(self, pos: QPointF) -> int:
            sdr_pixel = self._nits_to_pixel(self.sdr_max_point[0], self.sdr_max_point[1])
            if (pos - sdr_pixel).manhattanLength() <= HANDLE_RADIUS + HIT_PADDING:
                return -2
            for index, (x, y) in enumerate(self.intermediate_points):
                pixel = self._nits_to_pixel(x, y)
                if (pos - pixel).manhattanLength() <= HANDLE_RADIUS + HIT_PADDING:
                    return index
            return -1

        def _draw_reference_overlay(self, painter: QPainter, plot: QRectF) -> None:
            reference = float(self.reference_nits)
            if reference <= 0.0:
                return
            ref_corner = self._nits_to_pixel(reference, reference)
            sdr_rect = QRectF(plot.left(), ref_corner.y(), plot.width(), plot.bottom() - ref_corner.y())
            painter.fillRect(sdr_rect, QColor(70, 110, 160, 50))
            if reference < self.peak_nits:
                painter.setPen(QPen(QColor(90, 140, 200, 140), 1, Qt.PenStyle.DashLine))
                painter.drawLine(self._nits_to_pixel(0.0, reference), self._nits_to_pixel(reference, reference))

        def _update_readout(self, input_nits: float) -> None:
            output = evaluate_tone_curve(self._full_curve(), input_nits)
            self.input_label.setText(f"Input: {round(input_nits)} nits")
            self.output_label.setText(f"Output: {round(output)} nits")

        def _emit_committed(self) -> None:
            sender = self.sender()
            if sender is self.peak_spin:
                self.peak_spin.interpretText()
                self._on_peak_spin_changed()
            elif sender is self.reference_spin:
                self.reference_spin.interpretText()
                self._on_reference_spin_changed()
            elif sender is self.black_point_spin:
                self.black_point_spin.interpretText()
                self._on_black_point_changed()
            elif sender is self.vibrance_spin:
                self.vibrance_spin.interpretText()
                self._on_vibrance_changed()
            elif sender is self.gamut_spin:
                self.gamut_spin.interpretText()
                self._on_gamut_changed()
            else:
                self._read_spin_values()
                self._sanitize_curve_points()
                self.update()
            self.committed.emit()

        def _on_black_point_changed(self) -> None:
            if self._block:
                return
            self.black_point_value = clamp_black(float(self.black_point_spin.value()))

        def _on_vibrance_changed(self) -> None:
            if self._block:
                return
            self.vibrance_value = clamp_vibrance(float(self.vibrance_spin.value()))

        def _on_gamut_changed(self) -> None:
            if self._block:
                return
            self.gamut_value = clamp_gamut_expansion(float(self.gamut_spin.value()))

        def _on_peak_spin_changed(self) -> None:
            if self._block:
                return
            previous_peak = self.peak_nits
            self.peak_nits = float(self.peak_spin.value())
            if previous_peak != self.peak_nits:
                self._maybe_snap_sdr_max_point(previous_peak)
            self._sync_spin_ranges()
            self._apply_active_preset()
            self._sanitize_curve_points()
            self.update()

        def _on_reference_spin_changed(self) -> None:
            if self._block:
                return
            self.peak_spin.interpretText()
            self.peak_nits = float(self.peak_spin.value())
            self.reference_nits = clamp_reference_nits(float(self.reference_spin.value()))
            self._enforce_peak_floor()
            self._apply_active_preset()
            self._sanitize_curve_points()
            self.update()

        def current_values(self) -> dict[str, object]:
            self._read_spin_values()
            self._sanitize_curve_points()
            return {
                "MaxNits": self.peak_nits,
                "ReferenceNits": self.reference_nits,
                "SdrMaxPoint": self.sdr_max_point,
                "ToneCurvePoints": list(self.intermediate_points),
                "ToneCurvePreset": self.tone_curve_preset,
                "ToneCurveUserPresetId": self.tone_curve_user_preset_id,
                "BlackPoint": float(self.black_point_value),
                "Vibrance": float(self.vibrance_value),
                "GamutExpansion": float(self.gamut_value),
            }

        def paintEvent(self, _event) -> None:  # noqa: ANN001, N802
            painter = QPainter(self)
            painter.setRenderHint(QPainter.RenderHint.Antialiasing, True)
            host = self._plot_host_rect()
            plot = self._plot_rect()
            painter.fillRect(host, QColor(32, 32, 32))

            painter.setPen(QColor(70, 70, 70))
            for i in range(1, 4):
                t = plot.left() + (plot.width() * i) / 4.0
                painter.drawLine(QPointF(t, plot.top()), QPointF(t, plot.bottom()))
                u = plot.top() + (plot.height() * i) / 4.0
                painter.drawLine(QPointF(plot.left(), u), QPointF(plot.right(), u))

            self._draw_reference_overlay(painter, plot)

            painter.setPen(QColor(90, 90, 90))
            painter.drawLine(
                self._nits_to_pixel(0.0, 0.0),
                self._nits_to_pixel(self.reference_nits, self.reference_nits),
            )

            curve = self._full_curve()
            if len(curve) >= 2:
                path = QPainterPath()
                start_x = curve[0][0]
                end_x = curve[-1][0]
                for sample in range(129):
                    input_nits = start_x + (end_x - start_x) * (sample / 128.0)
                    output = evaluate_tone_curve(curve, input_nits)
                    pixel = self._nits_to_pixel(input_nits, output)
                    if sample == 0:
                        path.moveTo(pixel)
                    else:
                        path.lineTo(pixel)
                painter.setPen(QPen(QColor(240, 240, 240), 2))
                painter.drawPath(path)

            painter.setBrush(QColor(160, 160, 160))
            painter.setPen(Qt.PenStyle.NoPen)
            painter.drawEllipse(self._nits_to_pixel(0.0, 0.0), 4, 4)

            painter.setBrush(Qt.GlobalColor.white)
            for x, y in self.intermediate_points:
                painter.drawEllipse(self._nits_to_pixel(x, y), HANDLE_RADIUS, HANDLE_RADIUS)
            painter.drawEllipse(
                self._nits_to_pixel(self.sdr_max_point[0], self.sdr_max_point[1]), HANDLE_RADIUS, HANDLE_RADIUS
            )

            painter.setPen(QColor(180, 180, 180))
            bottom_label_height = host.bottom() - plot.bottom()
            painter.drawText(
                QRectF(plot.left(), plot.bottom(), plot.width() / 2.0, bottom_label_height),
                Qt.AlignmentFlag.AlignLeft | Qt.AlignmentFlag.AlignTop,
                "0 nits",
            )
            painter.drawText(
                QRectF(plot.center().x(), plot.bottom(), plot.width() / 2.0, bottom_label_height),
                Qt.AlignmentFlag.AlignRight | Qt.AlignmentFlag.AlignTop,
                f"{round(self.reference_nits)} SDR nits",
            )
            painter.drawText(
                QRectF(host.left(), host.top(), host.width() * 0.55, PLOT_LABEL_TOP),
                Qt.AlignmentFlag.AlignLeft | Qt.AlignmentFlag.AlignVCenter,
                f"{round(self.peak_nits)} nits",
            )

        def eventFilter(self, watched: QObject, event: QEvent) -> bool:  # noqa: N802
            if watched is not self.plot_host:
                return super().eventFilter(watched, event)

            if event.type() in {
                QEvent.Type.MouseButtonPress,
                QEvent.Type.MouseButtonRelease,
                QEvent.Type.MouseMove,
                QEvent.Type.MouseButtonDblClick,
                QEvent.Type.ContextMenu,
            }:
                mouse_event = event
                assert isinstance(mouse_event, QMouseEvent)
                mapped_pos = self._map_plot_event_pos(mouse_event.position())
                if event.type() == QEvent.Type.MouseButtonPress:
                    self._handle_plot_mouse_press(mapped_pos, mouse_event.modifiers())
                    return True
                if event.type() == QEvent.Type.MouseMove:
                    self._handle_plot_mouse_move(mapped_pos)
                    return True
                if event.type() == QEvent.Type.MouseButtonRelease:
                    self._handle_plot_mouse_release()
                    return True
                if event.type() == QEvent.Type.MouseButtonDblClick:
                    self._handle_plot_mouse_double_click(mapped_pos)
                    return True
                if event.type() == QEvent.Type.ContextMenu:
                    self._handle_plot_context_menu(mapped_pos, mouse_event.globalPosition().toPoint())
                    return True
            return super().eventFilter(watched, event)

        def _handle_plot_mouse_press(self, pos: QPointF, modifiers: Qt.KeyboardModifier) -> None:
            hit = self._hit_test(pos)
            if modifiers & Qt.KeyboardModifier.ControlModifier and hit >= 0:
                del self.intermediate_points[hit]
                self._selected_index = -1
                self._mark_custom_preset()
                self._sanitize_curve_points()
                self.update()
                self._emit_committed()
                return
            if hit == -2:
                self._drag_target = "sdr"
                self._selected_index = -2
                self.setFocus()
            elif hit >= 0:
                self._drag_target = "mid"
                self._drag_index = hit
                self._selected_index = hit
                self.setFocus()
            else:
                return
            input_nits, _ = self._pixel_to_nits(pos)
            self._update_readout(input_nits)

        def _handle_plot_mouse_move(self, pos: QPointF) -> None:
            if self._drag_target is None:
                if self._interactive_rect().contains(pos):
                    input_nits, _ = self._pixel_to_nits(pos)
                    self._update_readout(input_nits)
                return

            self._mark_custom_preset()
            input_nits, output_nits = self._pixel_to_nits(pos)
            max_input = self.reference_nits
            if self._drag_target == "sdr":
                clamped_x = max(0.0, min(max_input, input_nits))
                clamped_y = max(0.0, min(self.peak_nits, output_nits))
                if abs(self.sdr_max_point[0] - max_input) <= 1.0:
                    self.sdr_max_point = (max_input, clamped_y)
                else:
                    self.sdr_max_point = (clamped_x, clamped_y)
                self._sanitize_curve_points()
            elif self._drag_target == "mid" and 0 <= self._drag_index < len(self.intermediate_points):
                x = max(1.0, min(max_input - 1.0, input_nits))
                y = max(0.0, min(self.peak_nits, output_nits))
                prev_x = self.intermediate_points[self._drag_index - 1][0] if self._drag_index > 0 else 0.0
                next_x = (
                    self.intermediate_points[self._drag_index + 1][0]
                    if self._drag_index + 1 < len(self.intermediate_points)
                    else self.sdr_max_point[0] - 1.0
                )
                x = max(prev_x + 1.0, min(x, next_x - 1.0))
                prev_y = self.intermediate_points[self._drag_index - 1][1] if self._drag_index > 0 else 0.0
                y = max(prev_y, y)
                self.intermediate_points[self._drag_index] = (x, y)
                self._sanitize_curve_points()
            self._update_readout(input_nits)
            self.update()

        def _handle_plot_mouse_release(self) -> None:
            if self._drag_target is not None:
                self._drag_target = None
                self._drag_index = -1
                self._emit_committed()

        def _handle_plot_mouse_double_click(self, pos: QPointF) -> None:
            if not self._plot_rect().contains(pos) or self._hit_test(pos) != -1:
                return
            input_nits, output_nits = self._pixel_to_nits(pos)
            input_nits = max(1.0, min(self.sdr_max_point[0] - 1.0, input_nits))
            output_nits = max(0.0, min(self.peak_nits, output_nits))
            self._mark_custom_preset()
            self.intermediate_points.append((input_nits, output_nits))
            self._sanitize_curve_points()
            self._emit_committed()

        def _handle_plot_context_menu(self, pos: QPointF, global_pos: QPoint) -> None:
            hit = self._hit_test(pos)
            if hit < 0:
                return
            from PySide6.QtWidgets import QMenu  # noqa: PLC0415

            menu = QMenu(self)
            remove_action = menu.addAction("Remove point")
            if menu.exec(global_pos) == remove_action:
                del self.intermediate_points[hit]
                self._selected_index = -1
                self._mark_custom_preset()
                self._sanitize_curve_points()
                self._emit_committed()

        def keyPressEvent(self, event: QKeyEvent) -> None:  # noqa: N802
            if event.key() not in {Qt.Key.Key_Delete, Qt.Key.Key_Backspace}:
                super().keyPressEvent(event)
                return
            if self._selected_index < 0 or self._selected_index >= len(self.intermediate_points):
                return
            del self.intermediate_points[self._selected_index]
            self._selected_index = -1
            self._mark_custom_preset()
            self._sanitize_curve_points()
            self._emit_committed()

    class CalibrationDialog(QDialog):
        def __init__(
            self,
            initial_settings: dict[str, object],
            dialog_baseline: dict[str, object],
            dialog_reference: int,
            dialog_max_nits: int,
            dialog_session: CalibrationSession,
            on_commit_curve,
            parent: QWidget | None = None,
        ) -> None:
            super().__init__(parent)
            self.baseline_settings = dialog_baseline
            self.session = dialog_session
            self.on_commit_curve = on_commit_curve

            title = "AutoHDR Calibration"
            if dialog_session.display_name:
                title = f"{title} — {dialog_session.display_name}"
            self.setWindowTitle(title)
            self.setMinimumWidth(560)

            layout = QVBoxLayout(self)

            self.tone_curve = ToneCurveEditor(dialog_reference, dialog_max_nits, initial_settings, self)
            self.tone_curve.committed.connect(self._commit_current)
            layout.addWidget(self.tone_curve)

            buttons = QDialogButtonBox(
                QDialogButtonBox.StandardButton.Ok | QDialogButtonBox.StandardButton.Cancel
            )
            confirm = buttons.button(QDialogButtonBox.StandardButton.Ok)
            if confirm is not None:
                confirm.setText("Confirm")
            buttons.accepted.connect(self._on_confirm)
            buttons.rejected.connect(self._on_cancel)
            layout.addWidget(buttons)

        def _commit_current(self) -> None:
            self.on_commit_curve(self.tone_curve.current_values())

        def _on_confirm(self) -> None:
            self.tone_curve.peak_spin.interpretText()
            self.tone_curve.reference_spin.interpretText()
            self.tone_curve.black_point_spin.interpretText()
            self.tone_curve.vibrance_spin.interpretText()
            self.tone_curve.gamut_spin.interpretText()
            if not self.on_commit_curve(self.tone_curve.current_values()):
                return
            self.accept()

        def _on_cancel(self) -> None:
            restore_baseline(self.baseline_settings, self.session)
            dbus_call("reloadSettings")
            self.reject()

    app = QApplication.instance()
    owns_app = app is None
    if owns_app:
        app = QApplication(sys.argv)

    def persist_curve(curve_values: dict[str, object]) -> bool:
        saved = settings_from_curve(curve_values, settings, reference, max_nits)
        if commit_settings_dict(saved, session):
            return True
        show_error(
            "AutoHDR could not apply settings via D-Bus.\n"
            "Enable the AutoHDR effect in System Settings, reload KWin, then try again."
        )
        return False

    dialog = CalibrationDialog(
        settings,
        baseline_settings,
        reference,
        max_nits,
        session,
        persist_curve,
    )
    result = dialog.exec()

    if owns_app:
        app.quit()

    return result == QDialog.DialogCode.Accepted


def show_error(message: str) -> None:
    if qt_available():
        from PySide6.QtWidgets import QApplication, QMessageBox  # noqa: PLC0415

        app = QApplication.instance()
        owns_app = app is None
        if owns_app:
            app = QApplication(sys.argv)
        QMessageBox.critical(None, "AutoHDR Calibration", message)
        if owns_app:
            app.quit()
        return
    print(message, file=sys.stderr)


def run_dialog() -> int:
    ensure_gui_environment()

    if not qt_available():
        print("Install python-pyside6 to use the AutoHDR calibration dialog.", file=sys.stderr)
        return 1

    ctx = calibration_context()
    if not ctx["app_key"]:
        show_error("AutoHDR calibration requires an active application window.")
        return 1

    reference, max_nits = read_hdr_limits()
    settings = read_settings(reference, max_nits, ctx["app_key"])
    baseline_settings = settings.copy()

    session = CalibrationSession(
        app_key=ctx["app_key"],
        display_name=ctx["display_name"] or ctx["app_key"],
        window_class=ctx["window_class"],
        resource_class=ctx["resource_class"],
        desktop_file=ctx["desktop_file"],
        is_new=ctx["is_new"],
    )

    if not run_qt_form(settings, baseline_settings, reference, max_nits, session):
        return 1

    return 0


def verify_tone_curve_invariants() -> None:
    encoded = "51:55,151:243"
    points = parse_tone_curve_points(encoded)
    assert len(points) == 2, f"expected 2 parsed points, got {len(points)} from {encoded!r}"
    assert points[0] == (51.0, 55.0)
    assert points[1] == (151.0, 243.0)

    ref = 203.0
    peak = 1000.0
    sdr = (203.0, 1000.0)
    curve = build_full_curve(sdr, ref, peak, points)
    assert len(curve) == 4, f"expected 4 knots, got {len(curve)}: {curve}"
    assert curve[0] == (0.0, 0.0)
    assert curve[-1][0] == 203.0

    with_mids = evaluate_tone_curve(curve, 50.0)
    without_mids = evaluate_tone_curve(build_full_curve(sdr, ref, peak, []), 50.0)
    assert abs(with_mids - without_mids) > 1.0, "intermediate points must change mapping at 50 nits"

    at_mid = evaluate_tone_curve(curve, 151.0)
    assert abs(at_mid - 243.0) < 2.0, f"curve must pass through (151, 243), got {at_mid}"

    lut = build_tone_curve_lut(curve, ref)
    assert len(lut) == 256
    assert abs(lut[62] - evaluate_tone_curve(curve, 50.0)) < 2.0

    assert preset_from_string("linear") == PRESET_LINEAR
    assert preset_from_string("SCURVE_BOOSTED") == PRESET_SCURVE_BOOSTED
    assert preset_from_string("unknown") == PRESET_CUSTOM
    assert preset_to_string(PRESET_EXPONENTIAL) == PRESET_EXPONENTIAL

    linear_settings = {
        "ReferenceNits": ref,
        "MaxNits": peak,
        "ToneCurvePreset": PRESET_LINEAR,
    }
    apply_tone_curve_preset(linear_settings)
    assert linear_settings["ToneCurvePoints"] == ""
    assert parse_sdr_max_point(str(linear_settings["SdrMaxPoint"]), (peak, peak)) == (ref, peak)

    for preset in BUILT_IN_PRESETS:
        if preset == PRESET_LINEAR:
            continue
        generated = generate_preset_intermediate_points(preset, ref, peak)
        assert len(generated) == 3, f"{preset} should produce 3 intermediate knots"
        ys = [y for _, y in generated]
        assert ys == sorted(ys), f"{preset} intermediate outputs must be monotonic"
        assert ys[-1] < peak, f"{preset} last knot must stay below peak endpoint"

    boosted_settings = {
        "ReferenceNits": ref,
        "MaxNits": peak,
        "ToneCurvePreset": PRESET_SCURVE_BOOSTED,
    }
    apply_tone_curve_preset(boosted_settings)
    boosted_low_peak = {
        "ReferenceNits": ref,
        "MaxNits": 800.0,
        "ToneCurvePreset": PRESET_SCURVE_BOOSTED,
    }
    apply_tone_curve_preset(boosted_low_peak)
    boosted_low_points = parse_tone_curve_points(str(boosted_low_peak["ToneCurvePoints"]))
    boosted_points = parse_tone_curve_points(str(boosted_settings["ToneCurvePoints"]))
    assert abs(boosted_low_points[1][1] / 800.0 - boosted_points[1][1] / peak) < 0.05

    detect_settings = {
        "ReferenceNits": ref,
        "MaxNits": peak,
        "SdrMaxPoint": format_sdr_max_point((ref, peak)),
        "ToneCurvePoints": boosted_settings["ToneCurvePoints"],
    }
    assert detect_matching_preset(detect_settings) == PRESET_SCURVE_BOOSTED

    assert preset_from_string("user") == PRESET_USER

    user_source = {
        "ReferenceNits": ref,
        "MaxNits": peak,
        "SdrMaxPoint": format_sdr_max_point((ref, peak)),
        "ToneCurvePoints": boosted_settings["ToneCurvePoints"],
        "ToneCurvePreset": PRESET_CUSTOM,
    }
    normalized = normalize_current_curve(user_source)
    normalized.id = "test_grade"
    normalized.display_name = "Test Grade"

    with tempfile.NamedTemporaryFile(mode="w", suffix=".cfg", delete=False) as tmp:
        tmp_cfg = Path(tmp.name)
    try:
        assert save_user_tone_curve_preset(tmp_cfg, normalized)
        loaded = load_user_tone_curve_preset(tmp_cfg, "test_grade")
        assert loaded is not None
        assert loaded.display_name == "Test Grade"
        assert len(loaded.normalized_points) == len(normalized.normalized_points)
        for (ax, ay), (bx, by) in zip(normalized.normalized_points, loaded.normalized_points):
            assert abs(ax - bx) < 1e-4 and abs(ay - by) < 1e-4
        assert abs(loaded.sdr_max_fraction[0] - 1.0) < 1e-4
        assert abs(loaded.sdr_max_fraction[1] - 1.0) < 1e-4

        apply_settings = {
            "ReferenceNits": ref,
            "MaxNits": peak,
            "ToneCurvePreset": PRESET_USER,
            "ToneCurveUserPresetId": "test_grade",
        }
        apply_tone_curve_preset(apply_settings, tmp_cfg)
        applied_points = parse_tone_curve_points(str(apply_settings["ToneCurvePoints"]))
        source_points = parse_tone_curve_points(str(boosted_settings["ToneCurvePoints"]))
        assert _points_match(applied_points, source_points, 2.0)

        scaled_settings = {
            "ReferenceNits": ref,
            "MaxNits": 800.0,
            "ToneCurvePreset": PRESET_USER,
            "ToneCurveUserPresetId": "test_grade",
        }
        apply_tone_curve_preset(scaled_settings, tmp_cfg)
        scaled_points = parse_tone_curve_points(str(scaled_settings["ToneCurvePoints"]))
        assert abs(scaled_points[1][1] / 800.0 - source_points[1][1] / peak) < 0.05

        assert delete_user_tone_curve_preset(tmp_cfg, "test_grade")
        assert load_user_tone_curve_preset(tmp_cfg, "test_grade") is None
    finally:
        tmp_cfg.unlink(missing_ok=True)

    print("verify_tone_curve_invariants: ok")


def main() -> int:
    if len(sys.argv) == 2 and sys.argv[1] == "--verify-tone-curve":
        verify_tone_curve_invariants()
        return 0

    try:
        return run_dialog()
    except Exception as error:  # noqa: BLE001 - show any startup failure in a dialog
        message = f"AutoHDR calibration failed:\n{error}"
        print(message, file=sys.stderr)
        if sys.argv[0].endswith("plasma-autohdr-calibrate") and len(sys.argv) == 1:
            show_error(message)
        return 1


if __name__ == "__main__":
    sys.exit(main())
