# CMake build directories
build/
cmake-build-*/
**/build/

# CMake generated files
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
install_manifest.txt
CTestTestfile.cmake
Makefile
*.ninja
.ninja_deps
.ninja_log
compile_commands.json

# Compiled binaries and libraries
*.o
*.obj
*.lo
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.exe

# Python bytecode
__pycache__/
*.py[cod]

# Qt / KDE autogen (MOC, UIC, RCC)
*_autogen/
moc_*.cpp
*.moc
ui_*.h
qrc_*.cpp

# IDE and editor files
.idea/
.vscode/
*.user
*.pro.user
*.autosave
.cache/
.ccls-cache/

# OS junk
.DS_Store
Thumbs.db
*~

# Node / pnpm (decky-autohdr)
node_modules/
.pnpm-store/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Decky frontend build output — keep index.js, drop maps
decky-autohdr/dist/*.map

# Python environments (future-proofing)
.venv/
venv/
*.egg-info/

# Editor / tooling (optional but keeps branch clean)
.cursor/
